          <Affliction identifier="bleeding" strength="50" />
          <Affliction identifier="stun" strength="9" />
        </Explosion>
      </StatusEffect>
      <StatusEffect type="OnImpact" target="This" allowwhenbroken="true" Condition="-8.0" />
      <!-- additional condition damage against somewhat sturdier characters -->
      <StatusEffect type="OnImpact" target="UseTarget,This" allowwhenbroken="true" Condition="-25.0" comparison="And">
        <Conditional entitytype="eq Character" />
        <Conditional Health="gte 200" />
      </StatusEffect>
