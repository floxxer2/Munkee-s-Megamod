      <Attack structuredamage="50" itemdamage="25" severlimbsprobability="2.5" penetration="0.4" targetforce="200">
        <Affliction identifier="explosiondamage" strength="50" />
        <Affliction identifier="bleeding" strength="6" />
        <Affliction identifier="stun" strength="1.75" />
      </Attack>
      <StatusEffect type="OnActive" target="This">
        <ParticleEmitter particle="bubbles" anglemin="0" anglemax="360" particleamount="5" velocitymin="0" velocitymax="50" scalemin="1" scalemax="3" />
      </StatusEffect>
      <StatusEffect type="OnImpact" target="This" allowwhenbroken="true">
        <!-- Triggers once, on direct hit deals a lot of damage -->
        <Conditional Condition="gte 99" />
        <SpawnItem identifier="thalamusflakshrapnel" spawnposition="This" count="9" aimspread="360" rotationtype="Collider" rotation="0" />
        <sound file="Content/Items/Weapons/ExplosionSmall1.ogg" selectionmode="Random" range="30000" />
